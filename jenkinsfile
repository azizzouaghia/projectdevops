                                    <a href="${SONAR_HOST_URL}/dashboard?id=devops_git" style="color: #3498db; text-decoration: none; font-weight: bold;">
                                        🔍 SonarQube Report
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 12px; border: 1px solid #f1f2f6; background: #f9f9f9;"><strong>Monitoring</strong></td>
